# Keep build contexts small and clean
**/node_modules
**/.next
**/.turbo
.venv
**/__pycache__
**/*.pyc
.mypy_cache
.ruff_cache
.pytest_cache
apps/web/coverage
apps/web/playwright-report
apps/web/test-results
# raw CSVs are re-downloaded during the build; keep the committed Wikidata JSON
data/raw/*.csv
data/raw/*.parquet
data/cache
data/*.db
.git
.github
docs/screenshots
*.log
.DS_Store
