# Kickoff Atlas environment configuration
# Copy to .env — every variable is OPTIONAL; the app runs fully without any.

# --- API (FastAPI) -----------------------------------------------------------
# SQLite by default; any SQLAlchemy URL works (PostgreSQL in production):
# KICKOFF_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/kickoff
KICKOFF_DATABASE_URL=sqlite:///./data/kickoff.db

# Comma-separated CORS origins (JSON list syntax):
# KICKOFF_CORS_ORIGINS=["http://localhost:3000"]

# Open-Meteo weather panels (keyless; disable to skip external calls):
KICKOFF_WEATHER_ENABLED=true

# Server-side cap for Monte Carlo requests:
KICKOFF_MAX_SIMULATIONS=20000

# --- Optional live-data enrichment --------------------------------------------
# Free credential from https://www.football-data.org/client/register
# Enables live fixture list + standings sync (attribution required by their ToS).
# Without it those capabilities honestly report "not configured".
# FOOTBALL_DATA_API_KEY=

# --- Web (Next.js) -------------------------------------------------------------
# Where the web server proxies API calls (Docker: http://api:8000)
API_INTERNAL_URL=http://localhost:8000
