ml/artifacts/*.pkl
ml/artifacts/*.parquet

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# --- Logs / tmp ---
*.log
logs/
tmp/
.cache/

# Runtime state (regenerated at API startup)
data/*.db
data/*.db-journal

# local AI-assistant instruction files (kept out of the public repo)
/?LAUDE.md
.?laude/
